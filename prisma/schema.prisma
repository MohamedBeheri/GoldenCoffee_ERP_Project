// This is your Prisma schema file
// learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============== ENUMS ==============
enum Role {
  ADMIN
  FACTORY
  WAREHOUSE
  SALES
  ACCOUNTANT
  DELEGATE
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum ProductType {
  RAW // بن أخضر خام
  FINISHED // منتج نهائي
}

enum PaymentType {
  CASH // فوري
  CREDIT // آجل
}

enum OrderStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  COMPLETED
  CANCELLED
  REFUNDED
}

// ============== USERS & AUTH ==============
model User {
  id        String     @id @default(cuid())
  name      String
  username  String     @unique
  password  String // hashed with bcrypt
  role      Role       @default(SALES)
  status    UserStatus @default(ACTIVE)
  lastLogin DateTime?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // Relations
  auditLogs      AuditLog[]
  purchases      Purchase[]
  productions    Production[]
  warehouseIns   WarehouseIn[]
  warehouseOuts  WarehouseOut[]
  invoices       Invoice[]
  deliveryOrders DeliveryOrder[]
  settlements    Settlement[]

  @@map("users")
}

// ============== PRODUCTS ==============
model Product {
  id        String      @id @default(cuid())
  name      String
  type      ProductType
  costPrice Decimal     @db.Decimal(10, 2) // سعر التكلفة
  sellPrice Decimal     @db.Decimal(10, 2) // سعر البيع
  minStock  Int         @default(0) // الحد الأدنى
  quantity  Int         @default(0) // الكمية الحالية
  unit      String      @default("كجم") // وحدة القياس
  isActive  Boolean     @default(true)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  // Relations
  purchaseItems    PurchaseItem[]
  productionItems  ProductionItem[]
  productionsAsRaw Production[]     @relation("ProductionRawProduct")
  invoiceItems     InvoiceItem[]
  deliveryItems    DeliveryItem[]
  warehouseIns     WarehouseIn[]
  warehouseOuts    WarehouseOut[]

  @@map("products")
}

// ============== SUPPLIERS ==============
model Supplier {
  id             String   @id @default(cuid())
  name           String
  phone          String?
  address        String?
  email          String?
  totalPurchases Decimal  @default(0) @db.Decimal(12, 2)
  rating         Int      @default(5)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  // Relations
  purchases Purchase[]

  @@map("suppliers")
}

// ============== PURCHASES (شراء بن أخضر) ==============
model Purchase {
  id          String      @id @default(cuid())
  invoiceNo   String      @unique // رقم الفاتورة الورقية
  supplierId  String
  totalAmount Decimal     @db.Decimal(12, 2)
  notes       String?
  status      OrderStatus @default(COMPLETED)
  createdAt   DateTime    @default(now())
  createdById String

  // Relations
  supplier Supplier       @relation(fields: [supplierId], references: [id])
  items    PurchaseItem[]
  creator  User           @relation(fields: [createdById], references: [id])

  @@map("purchases")
}

model PurchaseItem {
  id         String  @id @default(cuid())
  purchaseId String
  productId  String
  quantity   Int
  unitPrice  Decimal @db.Decimal(10, 2)
  totalPrice Decimal @db.Decimal(10, 2)

  // Relations
  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])

  @@map("purchase_items")
}

// ============== PRODUCTION (التصنيع) ==============
model Production {
  id           String      @id @default(cuid())
  orderNo      String      @unique
  rawProductId String? // الخامة المستخدمة (نوع البن الأخضر)
  rawUsed      Int // كمية الخام المستخدم (كجم)
  stage        String      @default("تحميص وطحن") // مرحلة التصنيع: تحميص / طحن / تعبئة
  opCost       Decimal     @default(0) @db.Decimal(10, 2) // تكلفة التشغيل
  notes        String?
  status       OrderStatus @default(COMPLETED)
  createdAt    DateTime    @default(now())
  createdById  String

  // Relations
  rawProduct Product?         @relation("ProductionRawProduct", fields: [rawProductId], references: [id])
  items      ProductionItem[]
  creator    User             @relation(fields: [createdById], references: [id])

  @@map("productions")
}

model ProductionItem {
  id           String @id @default(cuid())
  productionId String
  productId    String
  quantity     Int // الكمية المنتجة

  // Relations
  production Production @relation(fields: [productionId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id])

  @@map("production_items")
}

// ============== WAREHOUSE (المخزن) ==============
model WarehouseIn {
  id          String   @id @default(cuid())
  productId   String
  quantity    Int
  source      String // المصدر (مثال: "المصنع - أمر تصنيع #1")
  notes       String?
  createdAt   DateTime @default(now())
  createdById String

  // Relations
  product Product @relation(fields: [productId], references: [id])
  creator User    @relation(fields: [createdById], references: [id])

  @@map("warehouse_ins")
}

model WarehouseOut {
  id          String   @id @default(cuid())
  productId   String
  quantity    Int
  target      String // الجهة (مثال: "مندوب: أحمد" أو "فرع رئيسي")
  reason      String // السبب (فاتورة بيع، أمر تسليم، مرتجعات)
  notes       String?
  createdAt   DateTime @default(now())
  createdById String

  // Relations
  product Product @relation(fields: [productId], references: [id])
  creator User    @relation(fields: [createdById], references: [id])

  @@map("warehouse_outs")
}

// ============== CUSTOMERS (العملاء) ==============
model Customer {
  id             String      @id @default(cuid())
  name           String
  phone          String?
  address        String?
  type           PaymentType @default(CASH)
  creditLimit    Decimal     @default(0) @db.Decimal(12, 2) // الحد الائتماني
  balance        Decimal     @default(0) @db.Decimal(12, 2) // الرصيد المدين
  totalPurchases Decimal     @default(0) @db.Decimal(12, 2)
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())

  // Relations
  invoices Invoice[]

  @@map("customers")
}

// ============== SALES POINTS (نقاط البيع) ==============
model SalesPoint {
  id        String   @id @default(cuid())
  name      String
  address   String?
  phone     String?
  manager   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  // Relations
  invoices Invoice[]

  @@map("sales_points")
}

// ============== INVOICES (فواتير البيع) ==============
model Invoice {
  id              String        @id @default(cuid())
  invoiceNo       String        @unique
  customerId      String
  totalAmount     Decimal       @db.Decimal(12, 2)
  discount        Decimal       @default(0) @db.Decimal(5, 2) // نسبة الخصم
  netAmount       Decimal       @db.Decimal(12, 2)
  type            PaymentType
  pointId         String?
  delegateId      String? // لو الفاتورة اتعملت أثناء جولة توزيع مندوب
  deliveryOrderId String? // الجولة المرتبطة
  status          InvoiceStatus @default(COMPLETED)
  createdAt       DateTime      @default(now())
  createdById     String

  // Relations
  customer      Customer       @relation(fields: [customerId], references: [id])
  point         SalesPoint?    @relation(fields: [pointId], references: [id])
  delegate      Delegate?      @relation(fields: [delegateId], references: [id])
  deliveryOrder DeliveryOrder? @relation(fields: [deliveryOrderId], references: [id])
  items         InvoiceItem[]
  creator       User           @relation(fields: [createdById], references: [id])

  @@map("invoices")
}

model InvoiceItem {
  id         String  @id @default(cuid())
  invoiceId  String
  productId  String
  quantity   Int
  unitPrice  Decimal @db.Decimal(10, 2)
  totalPrice Decimal @db.Decimal(10, 2)

  // Relations
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("invoice_items")
}

// ============== DELEGATES (المندوبين) ==============
model Delegate {
  id             String   @id @default(cuid())
  name           String
  phone          String?
  carNumber      String? // رقم العربية
  area           String? // المنطقة
  commissionRate Decimal  @default(5) @db.Decimal(5, 2) // نسبة العمولة
  totalSales     Decimal  @default(0) @db.Decimal(12, 2)
  commissionDue  Decimal  @default(0) @db.Decimal(12, 2)
  commissionPaid Decimal  @default(0) @db.Decimal(12, 2)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  // Relations
  deliveryOrders DeliveryOrder[]
  settlements    Settlement[]
  invoices       Invoice[]

  @@map("delegates")
}

// ============== DELIVERY ORDERS (أوامر التسليم) ==============
model DeliveryOrder {
  id          String      @id @default(cuid())
  orderNo     String      @unique
  delegateId  String
  status      OrderStatus @default(PENDING)
  notes       String?
  createdAt   DateTime    @default(now())
  createdById String

  // Relations
  delegate   Delegate       @relation(fields: [delegateId], references: [id])
  items      DeliveryItem[]
  invoices   Invoice[]
  settlement Settlement?
  creator    User           @relation(fields: [createdById], references: [id])

  @@map("delivery_orders")
}

model DeliveryItem {
  id              String @id @default(cuid())
  deliveryOrderId String
  productId       String
  quantity        Int

  // Relations
  deliveryOrder DeliveryOrder @relation(fields: [deliveryOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])

  @@map("delivery_items")
}

// ============== SETTLEMENTS (تسويات المندوبين) ==============
model Settlement {
  id              String   @id @default(cuid())
  delegateId      String
  deliveryOrderId String?  @unique // الجولة اللي التسوية دي بتاعتها
  soldQty         Int      @default(0) // المباع
  returnedQty     Int      @default(0) // المرتجع
  cashAmount      Decimal  @default(0) @db.Decimal(12, 2) // النقدية
  creditAmount    Decimal  @default(0) @db.Decimal(12, 2) // الآجل
  commission      Decimal  @default(0) @db.Decimal(12, 2) // العمولة
  notes           String?
  createdAt       DateTime @default(now())
  createdById     String

  // Relations
  delegate      Delegate       @relation(fields: [delegateId], references: [id])
  deliveryOrder DeliveryOrder? @relation(fields: [deliveryOrderId], references: [id])
  creator       User           @relation(fields: [createdById], references: [id])

  @@map("settlements")
}

// ============== CASH FLOW (التدفق النقدي) ==============
model CashFlow {
  id          String   @id @default(cuid())
  description String
  type        String // "IN" or "OUT"
  amount      Decimal  @db.Decimal(12, 2)
  balance     Decimal  @db.Decimal(12, 2)
  reference   String? // رقم الفاتورة/الأمر
  createdAt   DateTime @default(now())

  @@map("cash_flow")
}

// ============== AUDIT LOG (سجل المراجعة) ==============
model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  action      String // نوع العملية
  description String // الوصف
  impact      String // التأثير
  ipAddress   String?
  createdAt   DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}
