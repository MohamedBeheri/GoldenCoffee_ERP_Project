# Database (PostgreSQL)
# For local: postgresql://postgres:postgres@localhost:5432/golden_coffee?schema=public
# For Render: will be auto-provided
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/golden_coffee?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-change-this-in-production-min-32-chars"

# App
NODE_ENV="development"
